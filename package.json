{
  "name": "resume-builder",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prepare": "lefthook install && pnpm codegen",
    "build": "next build",
    "dev": "pnpm docker:up; next dev --no-server-fast-refresh",
    "devsafe": "rm -rf .next && next dev",
    "generate:importmap": "payload generate:importmap",
    "generate:types": "payload generate:types",
    "generate:db-schema": "payload generate:db-schema",
    "codegen": "pnpm generate:importmap && pnpm generate:types && pnpm generate:db-schema && next typegen",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "payload": "payload",
    "start": "next start",
    "docker:up": "echo \"Spinning up docker-compose.${NODE_ENV:-local}.yml\" && docker compose -f docker-compose.${NODE_ENV:-local}.yml up -d --wait",
    "docker:down": "echo \"Spinning down docker-compose.${NODE_ENV:-local}.yml\" && docker compose -f docker-compose.${NODE_ENV:-local}.yml down",
    "docker:cleanup": "echo \"Spinning down docker-compose.${NODE_ENV:-local}.yml and cleaning up volumes\" && docker compose -f docker-compose.${NODE_ENV:-local}.yml down --remove-orphans",
    "test": "pnpm test:e2e && pnpm test:int",
    "test:e2e": "NODE_ENV=test COMPOSE_PROJECT_NAME=resume-builder-playwright dotenvx run --convention=nextjs -- bash -c 'pnpm docker:up; playwright test --config=playwright.config.ts; pnpm docker:cleanup'",
    "test:int": "vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.62.0",
    "@google/genai": "^1.50.1",
    "@googlemaps/places": "^2.4.0",
    "@next/env": "^16.2.4",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tailwindcss/postcss": "^4.2.4",
    "@valibot/to-json-schema": "^1.6.0",
    "cheerio": "^1.2.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.8.1",
    "jsdom": "28.0.0",
    "next": "16.2.3",
    "payload": "3.84.1",
    "playwright": "1.59.1",
    "postcss": "^8.5.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.34.2",
    "tailwindcss": "^4.2.4",
    "turndown": "^7.2.4",
    "typescript-result": "^3.5.2",
    "uuid": "^14.0.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "1.59.1",
    "@testing-library/react": "16.3.0",
    "@types/google.maps": "^3.64.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "4.5.2",
    "jsdom": "28.0.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsx": "4.21.0",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  }
}
